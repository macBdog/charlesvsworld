{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Build + Serve",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash deploy.sh build && python -m http.server 8080 --directory _build",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Serve (no build)",
      "type": "node-terminal",
      "request": "launch",
      "command": "python -m http.server 8080",
      "cwd": "${workspaceFolder}"
    }
  ]
}
